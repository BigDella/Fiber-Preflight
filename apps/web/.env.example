# Fiber node JSON-RPC endpoint (server-side only, never exposed to the browser)
FIBER_RPC_URL=http://127.0.0.1:8227

# Set to "true" to run against the built-in fixture network (zero infrastructure).
# When FIBER_RPC_URL is unset, mock mode is used automatically.
FIBER_MOCK=true

# Set to "1" to log raw RPC payloads at debug level
FIBER_DEBUG=0
